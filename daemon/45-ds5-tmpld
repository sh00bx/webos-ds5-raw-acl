#!/bin/sh
# webosbrew boot hook (run-parts /var/lib/webosbrew/init.d): start the DS5 raw-ACL
# template publisher as a detached daemon. Lets the jailed Aurora app inject 0x36
# controller-audio reports in-process via raw HCI ACL, bypassing webOS BT
# one-outstanding flow control (the on-air metering that caused audio dropouts).
# Fire-and-forget: a hung/crashing boot hook would trip webosbrew failsafe.
# Filename has NO dot on purpose (busybox run-parts skips names with dots).
# NOTE: busybox start-stop-daemon's --exec already-running check can NOT match a
# shell script (it compares /proc/<pid>/exe, which for a script is the interpreter
# /bin/sh, never the script path) — the REAL duplicate-start guard is the pidfile
# check inside ds5-tmpld.sh itself. --background is kept only to detach the
# supervisor so this hook returns immediately.
start-stop-daemon --start --background --exec /var/lib/webosbrew/ds5-tmpld.sh
